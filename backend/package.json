{
  "name": "upgrade-advisor-backend",
  "version": "1.0.0",
  "description": "",
  "main": "app.ts",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "npm run build:ts && fastify start --pretty-print -l info dist/backend/src/app.js",
    "start:prod": "node dist/backend/src/server.js",
    "build:ts": "tsc",
    "watch:ts": "tsc -w",
    "predev": "pkill -f 'fastify start' 2>/dev/null; lsof -ti:${PORT:-3000} | xargs kill -9 2>/dev/null; sleep 0.5; true",
    "dev": "npm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
    "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/backend/src/app.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^6.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/redis": "^7.2.0",
    "@fastify/sensible": "^6.0.0",
    "@upgrade-advisor/backend-core": "*",
    "@upgrade-advisor/shared": "*",
    "bullmq": "^5.78.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "fastify-cli": "^8.0.0",
    "fastify-plugin": "^5.0.0",
    "pg": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "resend": "^6.12.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.10",
    "fastify-tsconfig": "^3.0.0",
    "ts-node": "^10.4.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2",
    "vitest": "^4.1.8"
  }
}
