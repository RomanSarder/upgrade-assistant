{
  "extends": "fastify-tsconfig",
  "compilerOptions": {
    "outDir": "dist",
    "sourceMap": true,
    "paths": {
      "@upgrade-advisor/shared": ["../packages/shared/src/index.ts"],
      "@upgrade-advisor/backend-core": ["../packages/backend-core/src/index.ts"],
      "@upgrade-advisor/backend-core/*": ["../packages/backend-core/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.test.ts"]
}
