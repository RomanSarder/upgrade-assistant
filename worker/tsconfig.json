{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "paths": {
      "@backend/*": ["../backend/src/*"],
      "@upgrade-advisor/shared": ["../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "../backend/src/**/*.ts"]
}
